# Local dev — IP máy chạy backend (chỉ cần set nếu Expo Go không tự nhận)
# VD: EXPO_PUBLIC_API_HOST=192.168.1.10
EXPO_PUBLIC_API_HOST=
EXPO_PUBLIC_API_PORT=3000

# Production web build — set trên Render/Vercel khi deploy
# EXPO_PUBLIC_API_ORIGIN=https://pho-ruong-api.onrender.com
# EXPO_PUBLIC_WS_URL=wss://pho-ruong-api.onrender.com/ws
